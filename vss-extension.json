{
  "manifestVersion": 1,
  "id": "my-branches",
  "name": "My Branches",
  "version": "0.1.0",
  "publisher": "CrazySolutions",
  "description": "Shows all branches created by the logged-in user across the organization and within each project's repositories.",
  "public": false,
  "categories": ["Azure Repos"],
  "tags": ["git", "branches"],
  "demands": ["api-version/5.1"],
  "scopes": ["vso.code"],
  "targets": [
    { "id": "Microsoft.VisualStudio.Services" }
  ],
  "icons": {
    "default": "images/logo.png"
  },
  "content": {
    "details": {
      "path": "overview.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "repository": {
    "type": "git",
    "uri": "https://github.com/Zezeq/ADO-Extension-My-Branches"
  },
  "links": {
    "support": {
      "uri": "https://github.com/Zezeq/ADO-Extension-My-Branches/issues"
    },
    "issues": {
      "uri": "https://github.com/Zezeq/ADO-Extension-My-Branches/issues"
    }
  },
  "contributions": [
    {
      "id": "org-hub",
      "type": "ms.vss-web.hub",
      "description": "My Branches at the organization/collection level",
      "targets": ["ms.vss-web.collection-overview-hub-group"],
      "properties": {
        "name": "My Branches",
        "order": 100,
        "uri": "dist/org-hub/index.html",
        "icon": "images/hub-icon.png"
      }
    },
    {
      "id": "repos-hub",
      "type": "ms.vss-web.hub",
      "description": "My Branches under Repos within a project",
      "targets": ["ms.vss-code-web.code-hub-group"],
      "properties": {
        "name": "My Branches",
        "order": 100,
        "uri": "dist/repos-hub/index.html",
        "icon": "images/hub-icon.png"
      }
    }
  ],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "node_modules/azure-devops-extension-sdk/SDK.min.js",
      "addressable": true,
      "packagePath": "lib/SDK.min.js"
    }
  ]
}
